# Gemini API Credentials (obtained from Google AI Studio)
# Set your API key below to connect to the live Gemini service.
# If left empty, the application automatically defaults to local Demo Mode.
GEMINI_API_KEY=your_gemini_api_key_here

# SQLite Database Connection string
# Defaults to creating a local file 'interview_system.db' in the project directory.
DATABASE_URL=sqlite:///./interview_system.db

# Target LLM Model selection
# Default is 'gemini-2.5-flash'
GEMINI_MODEL=gemini-2.5-flash

# Explicit Demo Mode Toggle
# If set to 'true', it forces the system to run locally with seed questions, bypassing API calls.
DEMO_MODE=false
